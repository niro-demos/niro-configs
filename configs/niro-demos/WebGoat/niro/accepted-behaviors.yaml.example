# accepted-behaviors.yaml — a risk-acceptance register.
#
# Every entry is a behavior treated as ACCEPTED: as long as an entry exists, the
# tool considers that behavior intended and does not re-report it. To stop
# accepting one, delete it — the finding comes back. Version control records who
# changed what, and when.
#
#   consequence:  [tool] the precise risk, in plain terms a non-expert can
#                 evaluate — what could actually happen. (max 1000 runes)
#   evidence:     [tool] proof it looks intentional — comment / test / flag /
#                 code, by file:line.
#   reason:       [human] your team's rationale for accepting this — your own
#                 documentation. The tool never writes it, and an entry is
#                 accepted by being here, not by this field. But fill it in: an
#                 undocumented acceptance no one can explain later is how real
#                 risk quietly gets forgotten.
#
# Be specific enough to adjudicate in seconds. Vague entries hide real bugs.
#
# This file accumulates across runs and is APPEND-ONLY. Anyone updating it — tool
# or human — must read it first, keep every existing entry (especially the human
# `reason`), and only append; never rewrite, reorder, or drop entries. Presence
# is the suppression signal, so a clobbered entry silently un-accepts a finding.
# COMMIT it to git — that is your history, your review trail, and your undo.
#
# Create `accepted-behaviors.yaml` next to this file, carrying this header into
# it so its rules travel with the data.

accepted_behaviors:
  # Added by the tool — accepted, rationale not yet documented:
  - consequence: "An admin can make the server send requests to arbitrary URLs, including internal-only hosts (SSRF)."
    evidence: "src/realm/idp.ts:142 — comment 'admin-configured, trusted'"
    reason: ""

  # With the team's documented rationale:
  - consequence: "A user importing records can set their created/updated timestamps, so imported history can be backdated."
    evidence: "test/import.spec.ts:88 asserts it"
    reason: "Bulk import must preserve original timestamps; only the import path allows it, and import is admin-gated."

# Too vague — a consequence like these can't be adjudicated and hides real bugs:
#   - consequence: "SSRF is accepted."
#   - consequence: "Admins can do anything."
